# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/myrentcard

# ─── Auth (Clerk) ─────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...

# ─── AI ───────────────────────────────────────────────────────────────────────
# Option A: Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...
# Option B: Replit AI integration (uses proxy)
# AI_INTEGRATIONS_ANTHROPIC_API_KEY=...
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=...

# OpenAI (used for audio/image features)
# AI_INTEGRATIONS_OPENAI_API_KEY=...
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Twilio (fallback / default account) ──────────────────────────────────────
# Per-account Twilio credentials are stored in the database.
# These are only used as fallbacks if no per-account credentials are set.
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
# Voice (optional — needed for Twilio Voice SDK)
# TWILIO_API_KEY_SID=SK...
# TWILIO_API_KEY_SECRET=...
# TWILIO_TWIML_APP_SID=AP...

# ─── Internal ────────────────────────────────────────────────────────────────
# Secret for /internal/* endpoints (process-interaction, retry-extraction)
INTERNAL_API_SECRET=change-me

# ─── Seed ─────────────────────────────────────────────────────────────────────
# Email of the Clerk user to assign as account owner during seeding
SEED_OWNER_EMAIL=you@example.com

# ─── Mobile App (Expo) ───────────────────────────────────────────────────────
# Set in artifacts/mobile/.env or eas.json build profiles
# EXPO_PUBLIC_DOMAIN=your-app.example.com
# EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# EXPO_PUBLIC_API_URL=https://your-app.example.com/api
